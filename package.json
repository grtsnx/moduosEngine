{
  "name": "penielvault",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"src/**/*.hbs\" \"prisma/**/*.prisma\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"src/**/*.hbs\" \"prisma/**/*.prisma\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "start:worker": "nest start --entryFile middleware/worker/worker",
    "start:worker:prod": "node dist/src/middleware/worker/worker",
    "postinstall": "bunx --bun prisma generate",
    "prisma:generate": "bunx --bun prisma generate",
    "prisma:migrate:dev": "bunx --bun prisma migrate dev",
    "prisma:migrate:deploy": "bunx --bun prisma migrate deploy",
    "prisma:seed": "bunx --bun prisma db seed",
    "seed:superadmin": "bun scripts/seed-superadmin.mjs",
    "rename:project": "bun scripts/rename-project.mjs",
    "prisma:studio": "bun --preload ./scripts/ignore-studio-pipe-errors.mjs ./node_modules/prisma/build/index.js studio",
    "auth:generate": "NODE_OPTIONS=--experimental-detect-module bun x @better-auth/cli@latest generate --config src/lib/betterauth/core/auth.cli.ts --yes",
    "test:auth": "jest --testPathPatterns=test/lib/betterauth/",
    "test:dto": "jest --testPathPatterns=test/dto/",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run check:betterauth-versions && bun run build && bun run test:cov && bun run test:e2e && bun run test:e2e:auth:if-configured && bun run audit:security",
    "check:betterauth-versions": "node scripts/check-betterauth-versions.mjs",
    "audit:security": "bun audit",
    "test": "jest",
    "test:app": "jest --testPathPatterns=test/app/",
    "test:redis": "jest --testPathPatterns='test/lib/redis/|test/middleware/common/redis-connection|test/middleware/common/wrap-redis-error'",
    "test:prisma": "jest --testPathPatterns=test/lib/prisma/",
    "test:queue": "jest --testPathPatterns=test/middleware/queue/",
    "test:email": "jest --testPathPatterns=test/lib/email/",
    "test:health": "jest --testPathPatterns=test/middleware/health/",
    "test:worker": "jest --testPathPatterns=test/middleware/worker/",
    "test:config": "jest --testPathPatterns=test/middleware/config/",
    "test:filters": "jest --testPathPatterns=test/middleware/filters/",
    "test:gravatar": "jest --testPathPatterns=test/lib/gravatar/",
    "test:platform": "jest --testPathPatterns=test/middleware/common/platform-context",
    "test:lib": "jest --testPathPatterns=test/lib/",
    "test:middleware": "jest --testPathPatterns=test/middleware/",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:auth": "bun test --timeout 20000 --preload ./test/e2e/setup-env-auth.ts ./test/e2e/auth-*.e2e-spec.ts",
    "test:e2e:auth:if-configured": "if [ -n \"${E2E_DATABASE_URL:-}\" ]; then bun run test:e2e:auth; else echo \"Skipping auth e2e (E2E_DATABASE_URL not set)\"; fi"
  },
  "dependencies": {
    "@better-auth/infra": "0.3.4",
    "@better-auth/passkey": "1.6.23",
    "@nestjs-modules/mailer": "^2.3.7",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@scalar/nestjs-api-reference": "^1.2.8",
    "@thallesp/nestjs-better-auth": "^2.7.0",
    "ai": "^7.0.15",
    "better-auth": "1.6.23",
    "better-auth-harmony": "^1.3.2",
    "bullmq": "^5.79.2",
    "cencori": "^1.2.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "gravatar": "^1.8.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "mem0ai": "^3.0.13",
    "moment-timezone": "^0.6.2",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/gravatar": "^1.8.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "prettier-plugin-prisma": "^5.0.0",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": "test/(app|middleware|lib|dto|modules|e2e/auth)/.*\\.spec\\.ts$",
    "setupFiles": [
      "<rootDir>/test/setup-env.ts"
    ],
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(better-auth|@better-auth)/)"
    ],
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1",
      "^test/fixtures$": "<rootDir>/test/fixtures/index.ts",
      "^test/fixtures/(.*)$": "<rootDir>/test/fixtures/$1",
      "^test/mocks/(.*)$": "<rootDir>/test/mocks/$1",
      "^generated/prisma/client$": "<rootDir>/test/mocks/prisma-client.mock.ts",
      "^better-auth/api$": "<rootDir>/test/mocks/better-auth-api.mock.ts",
      "^better-auth$": "<rootDir>/test/mocks/better-auth.mock.ts",
      "^better-auth/adapters/prisma$": "<rootDir>/test/mocks/better-auth-prisma-adapter.mock.ts",
      "^better-auth/plugins/admin$": "<rootDir>/test/mocks/better-auth-plugins.mock.ts",
      "^better-auth/plugins/bearer$": "<rootDir>/test/mocks/better-auth-plugins.mock.ts",
      "^better-auth/plugins$": "<rootDir>/test/mocks/better-auth-plugins.mock.ts",
      "^better-auth/plugins/organization$": "<rootDir>/test/mocks/better-auth-plugins.mock.ts",
      "^better-auth/plugins/two-factor$": "<rootDir>/test/mocks/better-auth-plugins.mock.ts",
      "^@better-auth/passkey$": "<rootDir>/test/mocks/better-auth-passkey.mock.ts",
      "^@better-auth/infra$": "<rootDir>/test/mocks/better-auth-infra.mock.ts",
      "^@thallesp/nestjs-better-auth$": "<rootDir>/test/mocks/nestjs-better-auth.mock.ts"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s",
      "!src/main.ts",
      "!src/lib/betterauth/core/auth.cli.ts",
      "!src/lib/betterauth/core/auth-options.ts",
      "!src/middleware/worker/worker.ts",
      "!src/**/*.module.ts",
      "!src/middleware/config/setup-api-docs.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "testEnvironment": "node"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "trustedDependencies": [
    "unrs-resolver"
  ],
  "overrides": {
    "@hono/node-server": "1.19.13",
    "multer": "2.2.0",
    "nodemailer": "9.0.3",
    "uuid": "11.1.1"
  }
}
