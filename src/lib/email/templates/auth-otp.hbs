{{> stripe-layout-open emailTitle=emailTitle}}
            <tr>
              <td style='padding: 0 48px 8px'>
                <h1
                  style='
                    margin: 0;
                    font-size: 28px;
                    font-weight: 600;
                    line-height: 1.3;
                    color: #0a2540;
                    letter-spacing: -0.02em;
                    word-wrap: break-word;
                    overflow-wrap: break-word;
                  '
                >
                  {{headline}}
                </h1>
              </td>
            </tr>

            <tr>
              <td style='padding: 16px 48px 0'>
                {{#if firstName}}
                  <p
                    style='
                      margin: 0;
                      font-size: 16px;
                      line-height: 1.6;
                      color: #425466;
                      word-wrap: break-word;
                      overflow-wrap: break-word;
                    '
                  >
                    Hi
                    {{firstName}},
                  </p>
                {{/if}}
                <p
                  style='
                    margin: {{#if firstName}}16px{{else}}0{{/if}} 0 0;
                    font-size: 16px;
                    line-height: 1.6;
                    color: #425466;
                    word-wrap: break-word;
                    overflow-wrap: break-word;
                  '
                >
                  {{bodyText}}
                </p>
              </td>
            </tr>

            <tr>
              <td style='padding: 16px 48px 0'>
                {{> stripe-otp-block otp=otp expiresMinutes=expiresMinutes}}
              </td>
            </tr>

            <tr>
              <td style='padding: 24px 48px 0'>
                <p
                  style='
                    margin: 0;
                    font-size: 14px;
                    line-height: 1.6;
                    color: #8898aa;
                    word-wrap: break-word;
                    overflow-wrap: break-word;
                  '
                >
                  If you did not request this code, you can safely ignore this
                  email.
                </p>
              </td>
            </tr>

{{> stripe-layout-close}}
