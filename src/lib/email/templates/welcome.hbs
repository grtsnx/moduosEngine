{{> stripe-layout-open emailTitle=(concat "Welcome to " platformName)}}
            <tr>
              <td style='padding: 0 48px 8px'>
                <h1
                  style='
                    margin: 0;
                    font-size: 28px;
                    font-weight: 600;
                    line-height: 1.3;
                    color: #0a2540;
                    letter-spacing: -0.02em;
                    word-wrap: break-word;
                    overflow-wrap: break-word;
                  '
                >
                  Welcome to
                  {{platformName}}
                </h1>
              </td>
            </tr>

            <tr>
              <td style='padding: 16px 48px 0'>
                <p
                  style='
                    margin: 0;
                    font-size: 16px;
                    line-height: 1.6;
                    color: #425466;
                    word-wrap: break-word;
                    overflow-wrap: break-word;
                  '
                >
                  Hi
                  {{firstName}},
                </p>
                <p
                  style='
                    margin: 16px 0 0;
                    font-size: 16px;
                    line-height: 1.6;
                    color: #425466;
                    word-wrap: break-word;
                    overflow-wrap: break-word;
                  '
                >
                  Thanks for joining
                  {{platformName}}. Your email is verified and your account is
                  ready. Get started by exploring your dashboard.
                </p>
              </td>
            </tr>

            {{#if ctaUrl}}
            <tr>
              <td style='padding: 32px 48px 0'>
                {{> stripe-button ctaUrl=ctaUrl ctaLabel="Go to dashboard"}}
              </td>
            </tr>

            <tr>
              <td style='padding: 32px 48px 0'>
                <p
                  style='
                    margin: 0;
                    font-size: 14px;
                    line-height: 1.6;
                    color: #8898aa;
                    word-wrap: break-word;
                    overflow-wrap: break-word;
                  '
                >
                  If the button does not work, copy and paste this link into your
                  browser:
                  <a
                    href='{{ctaUrl}}'
                    style='color: {{brandColor}}; word-break: break-all'
                  >{{ctaUrl}}</a>
                </p>
              </td>
            </tr>
            {{/if}}

{{> stripe-layout-close}}
