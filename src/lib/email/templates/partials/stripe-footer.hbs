<tr>
  <td style='padding: 40px 48px'>
    <hr
      style='
        border: none;
        border-top: 1px solid #e6ebf1;
        margin: 0 0 24px;
      '
    />
    <p
      style='
        margin: 0;
        font-size: 12px;
        line-height: 1.6;
        color: #8898aa;
        word-wrap: break-word;
        overflow-wrap: break-word;
      '
    >
      Questions? Contact us at
      <a
        href='mailto:{{platformSupport}}'
        style='color: {{brandColor}}; text-decoration: none'
      >{{platformSupport}}</a>
    </p>
    <p
      style='
        margin: 12px 0 0;
        font-size: 12px;
        line-height: 1.6;
        color: #8898aa;
      '
    >
      &copy;
      {{year}}
      {{platformName}}. All rights reserved.
    </p>
  </td>
</tr>
