<table
  role='presentation'
  width='100%'
  cellspacing='0'
  cellpadding='0'
  style='
    margin: 24px 0 0;
    background-color: #f6f9fc;
    border-radius: 8px;
    border: 1px solid #e6ebf1;
  '
>
  <tr>
    <td align='center' style='padding: 24px 16px'>
      <p
        style='
          margin: 0 0 8px;
          font-size: 12px;
          font-weight: 600;
          letter-spacing: 0.08em;
          text-transform: uppercase;
          color: #8898aa;
        '
      >
        Your verification code
      </p>
      <p
        style='
          margin: 0;
          font-size: 36px;
          font-weight: 600;
          letter-spacing: 0.2em;
          color: #0a2540;
          font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
            monospace;
          word-wrap: break-word;
          overflow-wrap: break-word;
          word-break: break-all;
        '
      >
        {{otp}}
      </p>
      {{#if expiresMinutes}}
        <p
          style='
            margin: 12px 0 0;
            font-size: 14px;
            line-height: 1.6;
            color: #8898aa;
            word-wrap: break-word;
            overflow-wrap: break-word;
          '
        >
          This code expires in
          {{expiresMinutes}}
          minutes.
        </p>
      {{/if}}
    </td>
  </tr>
</table>
