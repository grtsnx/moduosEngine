{{> stripe-layout-open emailTitle=(concat "Invitation to join " organizationName)}}
            <tr>
              <td style='padding: 0 48px 8px'>
                <h1
                  style='
                    margin: 0;
                    font-size: 28px;
                    font-weight: 600;
                    line-height: 1.3;
                    color: #0a2540;
                    letter-spacing: -0.02em;
                    word-wrap: break-word;
                    overflow-wrap: break-word;
                  '
                >
                  You are invited to join
                  {{organizationName}}
                </h1>
              </td>
            </tr>

            <tr>
              <td style='padding: 16px 48px 0'>
                <p
                  style='
                    margin: 0;
                    font-size: 16px;
                    line-height: 1.6;
                    color: #425466;
                    word-wrap: break-word;
                    overflow-wrap: break-word;
                  '
                >
                  {{inviterName}}
                  invited you to join
                  {{organizationName}}
                  on
                  {{platformName}}
                  {{#if role}}
                    as
                    {{role}}.
                  {{else}}
                    .
                  {{/if}}
                </p>
                <p
                  style='
                    margin: 16px 0 0;
                    font-size: 16px;
                    line-height: 1.6;
                    color: #425466;
                    word-wrap: break-word;
                    overflow-wrap: break-word;
                  '
                >
                  Accept the invitation to start collaborating with your team.
                </p>
              </td>
            </tr>

            {{#if inviteUrl}}
            <tr>
              <td style='padding: 32px 48px 0'>
                {{> stripe-button ctaUrl=inviteUrl ctaLabel="Accept invitation"}}
              </td>
            </tr>

            <tr>
              <td style='padding: 32px 48px 0'>
                <p
                  style='
                    margin: 0;
                    font-size: 14px;
                    line-height: 1.6;
                    color: #8898aa;
                    word-wrap: break-word;
                    overflow-wrap: break-word;
                  '
                >
                  If the button does not work, copy and paste this link into your
                  browser:
                  <a
                    href='{{inviteUrl}}'
                    style='color: {{brandColor}}; word-break: break-all'
                  >{{inviteUrl}}</a>
                </p>
              </td>
            </tr>
            {{/if}}

{{> stripe-layout-close}}
