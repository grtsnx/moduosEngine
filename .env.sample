# Server
PORT=3000
NODE_ENV=development
# Set false unless deployed behind a trusted reverse proxy/load balancer.
# Allowed values: false, true, or a positive integer proxy hop count.
TRUST_PROXY=false

# GitHub Actions CI kill switch (NOT a local env var — set on GitHub only):
#   Settings → Secrets and variables → Actions → VARIABLES tab (not Secrets)
#   New repository variable:
#     Name  = CI_ENABLED
#     Value = false
#   Wrong: creating a Secret, or putting "CI_ENABLED = false" in the value box.
# Effect: skips push/PR CI; "CI Success" stays green; manual Run workflow still works.
# Re-enable: delete the variable or set Value to anything other than false.
# Full steps: README → CI → Disable CI.

# Public URLs (required when NODE_ENV=production)
PRODUCTION_URL=http://localhost:3000
DEVELOPMENT_URL=http://localhost:3000
PLATFORM_URL=http://localhost:3000

# Application (PLATFORM_NAME required in production)
PLATFORM_NAME=your-platform
ENABLE_API_DOCS=true
LOG_LEVEL=info

# Rate limiting (requests per IP per window)
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=30

# Comma-separated extra CORS origins (optional)
# Also added to Better Auth trustedOrigins for callbackURL validation.
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
# In production, all values must be HTTPS.
CORS_ORIGINS=

# Redis (required in production; optional in development)
# REDIS_URL=redis://localhost:6379

# PostgreSQL (required in production)
# DATABASE_URL=postgresql://user:pass@localhost:5432/penielvault

# Auth integration e2e only (optional; never point at dev/prod DATABASE_URL)
# E2E_DATABASE_URL=postgresql://user:pass@localhost:5432/penielvault_test

# Email (PLATFORM_SUPPORT required; smtp/google credentials required when DATABASE_URL is set)
# With DATABASE_URL set, EMAIL_PROVIDER must be smtp or google (not test).
EMAIL_PROVIDER=smtp
PLATFORM_SUPPORT=noreply@example.com
PLATFORM_LOGO_URL=
COLOR_CODE=#635BFF

# Google email (when EMAIL_PROVIDER=google)
# EMAIL_ADDRESS=
# EMAIL_PASSWORD=

# SMTP email (required when EMAIL_PROVIDER=smtp and DATABASE_URL is set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Better Auth (BETTER_AUTH_SECRET required when DATABASE_URL is set, min 32 chars)
# Generate: bun x @better-auth/cli@latest secret
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=http://localhost:3000
# In production, BETTER_AUTH_URL must be HTTPS.
# When tunneling (ngrok, etc.) for the Better Auth Infrastructure dashboard, set this to your public URL.

# Better Auth Infrastructure (optional in dev; required for Dash analytics in production)
# BETTER_AUTH_API_KEY=
# BETTER_AUTH_API_URL=
# BETTER_AUTH_IDENTIFY_URL=https://kv.better-auth.com/projects/your-project-id
# Optional: defaults to true when BETTER_AUTH_API_KEY is set. Keep enabled to fail fast on dash schema drift.
# BETTER_AUTH_DASH_STARTUP_CHECKS=true
# Optional: surface Better Auth warn-level logs (default off). Handy for debugging, noisy otherwise.
# BETTER_AUTH_DEBUG_LOGS=false
# Optional: API-backed email validation (disposable/spam detection). Gated feature; leave off unless
# enabled on your Better Auth plan, otherwise /email/validate 404s and fails open on every sign-up.
# BETTER_AUTH_EMAIL_VALIDATION=false
# Ngrok/local proxy mode: keep BETTER_AUTH_URL, PRODUCTION_URL, and PLATFORM_URL on the same active ngrok origin.
# Better Auth per-endpoint rate limit settings (seconds and max requests)
BETTER_AUTH_RATE_LIMIT_WINDOW=60
BETTER_AUTH_RATE_LIMIT_MAX=100

# Cloudflare Turnstile captcha (off by default)
# Backend only needs TURNSTILE_SECRET_KEY. Site key belongs in the frontend app.
# When CAPTCHA_ENABLED=true, protected auth POSTs require header `x-captcha-response`.
# Create keys at https://dash.cloudflare.com/?to=/:account/turnstile
CAPTCHA_ENABLED=false
# TURNSTILE_SECRET_KEY=

# Backoffice superadmin seed (optional)
# Quick setup: `bun run seed:superadmin` writes these vars and runs the seed.
# Manual seed: set vars below, then `bun run prisma:seed` after migrate.
# BACKOFFICE_ADMIN_EMAIL=superadmin@penielvault.local
# BACKOFFICE_ADMIN_PASSWORD=
# BACKOFFICE_ADMIN_NAME=Superadmin

# Social OAuth (optional; register only when both ID and secret are set)
# Provider redirect URI to register: {BETTER_AUTH_URL}/v1/api/auth/callback/{provider}
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
